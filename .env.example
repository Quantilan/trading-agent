# ─────────────────────────────────────────────────────────
#  TRADING AGENT — CONFIGURATION
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────


# ─── Control / Notifications TELEGRAM BOT ─────────────────
TG_TOKEN=your-personal-bot-token # if You have own TG bot
TG_CHAT_ID=your-chat-id  # You id from @userinfobot


# ─── Exchange ─────────────────────────────────────────────
# binance | bybit | hyperliquid | okx
EXCHANGE=binance
EXCHANGE_API_KEY=your-api-key
EXCHANGE_SECRET=your-secret-key
# EXCHANGE_STBC=USDT   # USDT (default) | USDC (Hyperliquid) — auto-detected if not set
# EXCHANGE_PASSPHRASE=    # OKX only
# EXCHANGE_WALLET_ADDRESS= # Hyperliquid only

# OKX add
# EXCHANGE_PASSPHRASE=your-passphrase

# Hyperliquid add
# EXCHANGE_WALLET_ADDRESS=0x...

# ─── Risk management ──────────────────────────────────────
MARGIN_PCT=4.0       # % of free balance per trade
LEVERAGE=5           # 1 = no leverage
MAX_POSITIONS=7      # max simultaneous open positions

# ─── Mode ─────────────────────────────────────────────────
# paper = test mode (no real orders placed)
# trade = live trading
MODE=paper

# ─── Signal source ────────────────────────────────────────

# License key from @quantilan_bot
# Need if you want to start trading with Quantilan Strategies
# or need control you trading agent via Quantilan Telegram Bot 
LICENSE_KEY=XXXX-XXXX-XXXX-XXXX

# server   = Quantilan WebSocket server (recommended)
# telegram = any Telegram channel with RegEx or LLM parsing
SIGNAL_SOURCE=server

# Quantilan server URL
SIGNAL_SERVER=wss://signals.quantilan.com

# Signal parser (for SIGNAL_SOURCE = telegram)  (forwarded messages / natural language via personal bot)
# PARSER_MODE=regex                 # regex (default) | llm
# CONFIRM_TRADE=true                # ask confirmation before executing parsed signal
# DEFAULT_SL_PCT=2.0                # default stop-loss % when not specified in signal

# LLM signal parser (used when PARSER_MODE=llm)
LLM_PROVIDER=none                   # none (default) | claude
# LLM_API_KEY=sk-ant-...            # Anthropic API key (required when LLM_PROVIDER=claude)
# LLM_MODEL=                        # auto: claude-haiku-4-5-20251001

# ─── Misc ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Chart notifications ───────────────────────────────────
# Timeframe for candlestick chart in Telegram notifications
# Options: 5m | 15m | 1h | 4h
CHART_TF=15m

# Number of candles to display on chart (25–100)
CHART_BARS=50
