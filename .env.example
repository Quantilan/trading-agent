# ─────────────────────────────────────────────────────────
#  TRADING AGENT — CONFIGURATION
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────


# ─── Telegram control bot ─────────────────────────────────
TG_TOKEN=your-personal-bot-token   # Your own Telegram bot token
TG_CHAT_ID=your-chat-id            # Your Telegram user ID (from @userinfobot)


# ─── Exchange ─────────────────────────────────────────────
# Supported: binance | bybit | hyperliquid | okx
EXCHANGE=binance
EXCHANGE_API_KEY=your-api-key
EXCHANGE_SECRET=your-secret-key

# Settlement currency — auto-detected if not set
# USDT (default for Binance/Bybit/OKX) | USDC (Hyperliquid)
# EXCHANGE_STBC=USDT

# OKX only
# EXCHANGE_PASSPHRASE=your-passphrase

# Hyperliquid only
# EXCHANGE_WALLET_ADDRESS=0x...
# EXCHANGE_SECRET=your-private-key


# ─── Risk management ──────────────────────────────────────
MARGIN_PCT=4.0       # % of free balance per trade
LEVERAGE=5           # position leverage (1 = no leverage)
MAX_POSITIONS=7      # max simultaneous open positions


# ─── Trading mode ─────────────────────────────────────────
# paper = virtual trading (no real orders placed)
# trade = live trading on exchange
MODE=paper
PAPER_BALANCE=10000  # virtual balance for paper mode (USDT)


# ─── Signal source ────────────────────────────────────────
# server   = Quantilan WebSocket server (requires LICENSE_KEY)
# telegram = forward messages from any Telegram channel (regex or LLM parser)
SIGNAL_SOURCE=telegram

# Required for SIGNAL_SOURCE=server
LICENSE_KEY=XXXX-XXXX-XXXX-XXXX
SIGNAL_SERVER=wss://signals.quantilan.com


# ─── Signal parser (SIGNAL_SOURCE=telegram) ───────────────
# regex = rule-based parser (fast, no API cost)
# llm   = LLM-based parser (more flexible, requires API key)
PARSER_MODE=regex

# Ask confirmation in Telegram before executing each signal
CONFIRM_TRADE=true

# Default stop-loss % when not specified in the signal
DEFAULT_SL_PCT=2.0


# ─── Entry zone (deferred entries) ────────────────────────
# Tolerance for matching current price to the signal entry zone.
# 0.1 means ±0.1% — if price is within this range the entry fires.
ENTRY_TOLERANCE=0.1

# Hours to wait for the price to reach the entry zone before cancelling.
PENDING_ENTRY_TIMEOUT=24


# ─── LLM signal parser ────────────────────────────────────
# Used when PARSER_MODE=llm
LLM_PROVIDER=none        # none (default) | claude
# LLM_API_KEY=sk-ant-... # Anthropic API key (required when LLM_PROVIDER=claude)
# LLM_MODEL=             # auto-selected if empty: claude-haiku-4-5-20251001


# ─── Chart notifications ──────────────────────────────────
# Candlestick chart sent to Telegram on position open/close/modify
# Timeframe options: 5m | 15m | 1h | 4h
CHART_TF=15m

# Number of candles to display (25–100)
CHART_BARS=50


# ─── Misc ─────────────────────────────────────────────────
LOG_LEVEL=INFO
