# agent/tg_channel_listener.py
"""
Telegram channel listener using Telethon (MTProto).

Monitors a specified Telegram channel and forwards new messages
to a callback for LLM parsing.

First-time setup:
  Run with --setup-telegram flag (see main.py) to authenticate
  and create the session file. After that, runs headlessly.

Session file: tg_session.session (in project root)
"""

import asyncio
import logging
from typing import Callable, Awaitable

logger = logging.getLogger(__name__)

SESSION_FILE = "tg_session"


class TelegramChannelListener:

    def __init__(
        self,
        api_id:   int,
        api_hash: str,
        channel:  str,
        on_message: Callable[[str], Awaitable[None]],
    ):
        self._api_id     = api_id
        self._api_hash   = api_hash
        self._channel    = channel
        self._on_message = on_message
        self._client     = None

    async def start(self) -> None:
        """Connect and listen for new messages. Reconnects on error."""
        from telethon import TelegramClient, events

        while True:
            try:
                self._client = TelegramClient(SESSION_FILE, self._api_id, self._api_hash)
                await self._client.start()

                entity = await self._client.get_entity(self._channel)
                logger.info(f"✅ [TgListener] Listening to: {getattr(entity, 'title', self._channel)}")

                @self._client.on(events.NewMessage(chats=entity))
                async def handler(event):
                    text = event.message.message or ""
                    if text.strip():
                        await self._on_message(text)

                await self._client.run_until_disconnected()

            except Exception as e:
                logger.error(f"❌ [TgListener] Error: {e} — reconnecting in 15s")
                await asyncio.sleep(15)

    async def stop(self) -> None:
        if self._client:
            await self._client.disconnect()
